---
import { siteConfig } from '../data/site';

const socialNetworks = [
  {
    key: 'email',
    url: (val: string) => `mailto:${val}`,
    icon: 'fas fa-envelope',
    title: 'Email'
  },
  {
    key: 'instagram',
    url: (val: string) => `https://www.instagram.com/${val}`,
    icon: 'fab fa-instagram',
    title: 'Instagram'
  },
  {
    key: 'linkedin',
    url: (val: string) => `https://linkedin.com/in/${val}`,
    icon: 'fab fa-linkedin',
    title: 'LinkedIn'
  }
] as const;

type SocialKey = typeof socialNetworks[number]['key'];
---

<ul class="footer-links">
  {socialNetworks.map((network) => {
    const value = siteConfig.socialLinks[network.key as SocialKey];
    if (!value) return null;

    return (
      <li>
        <a
          href={network.url(value)}
          title={network.title}
          target="_blank"
          rel="noopener noreferrer"
        >
          <span class={network.icon} aria-hidden="true"></span>
          <span class="sr-only">{network.title}</span>
        </a>
      </li>
    );
  })}
</ul>

<style>
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>
